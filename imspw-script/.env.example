DEVICE_ID=100.123.8.13:5555
# LINE + Messenger: DB monitor. WhatsApp: Frida only.
LINE_USE_DB_POLL=1
MESSENGER_USE_DB_POLL=1
LINE_MONITOR_INTERVAL=1.0
# LINE background: keepalive ping interval (default 15s). Re-apply battery whitelist every LINE_BACKGROUND_CONFIG_INTERVAL (default 300).
# LINE_KEEPALIVE_INTERVAL=15
# LINE_BACKGROUND_CONFIG_INTERVAL=300
# Optional: if LINE does not receive in background, set LINE_WAKE_FOREGROUND_INTERVAL=60 or 120 to bring LINE to foreground briefly to sync. Default 0 (disabled).
# LINE_WAKE_FOREGROUND_INTERVAL=0
# 0=always poll every interval (real-time, default). 1=skip when file size unchanged (can miss short messages).
# LINE_USE_SIZE_TRIGGER=0
# Use FTS DB by default (1=default for new LINE). 0=naver_line only (older LINE).
# LINE_USE_FTS_DB=1
# Debug: log each FTS poll, always poll (skip size trigger). Set LINE_DEBUG=1 to troubleshoot.
# LINE_DEBUG=0
# Attach-only: LINE/Messenger need app open first. Spawn works for WhatsApp.
# FRIDA_ATTACH_ONLY=1              # All packages attach-only
# FRIDA_ATTACH_ONLY_PACKAGES=jp.naver.line.android,com.facebook.orca  # Per-package
TARGET_PACKAGES=jp.naver.line.android,com.whatsapp,org.telegram.messenger
# SERVICE=my-service  # 发送到 processor 的 payload 中的 service 字段，未设置时使用 APP_NAME 或 app_name
PROCESSOR_URL=http://localhost:8000/api/webhook
PROCESSOR_API_KEY=your_api_key_here
PROCESSOR_API_SECRET=your_api_secret_here

# Telegram MTProto (Telethon)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TG_SESSION_STRING=

# Contact core (contacts.db path, default: project root)
# CONTACTS_DB_PATH=./contacts.db

# Callback message receiver server (接收外部 POST 回调并转发到 LINE/WhatsApp/Telegram/Messenger)
# 默认随 main 启动。设为 0 可禁用。
# CALLBACK_SERVER_ENABLED=1
CALLBACK_SERVER_PORT=8091
# CALLBACK_API_SECRET=your_callback_secret
# CALLBACK_USE_PROCESSOR=1   # 1=通过 processor 队列（与 main 同进程），0=直接调用服务（独立运行）

# Daily phone restart at 00:00 + auto-start frida-server (set PHONE_RESTART_HOUR=-1 to disable)
# PHONE_RESTART_HOUR=0
# PHONE_RESTART_MINUTE=0
# FRIDA_SERVER_PATH=/data/local/tmp/frida-server
# PHONE_BOOT_WAIT_SEC=90